# Next.js Environment Variables
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Development flags
NODE_ENV=development

