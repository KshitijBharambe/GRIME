# ============================================================================
# Environment Variables - Production Simulation
# Data Hygiene Toolkit
# 
# Copy this file to .env.prod-sim for production simulation testing
# This simulates production configuration but runs locally
# ============================================================================

# Environment
ENVIRONMENT=production
DEBUG=false
BUILD_TARGET=production
NODE_ENV=production

# Database (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=prodpassword
POSTGRES_DB=data_hygiene_prod
POSTGRES_PORT=5433  # Different port to avoid conflicts

# Database URLs (internal Docker network)
DATABASE_URL=postgresql://admin:prodpassword@postgres:5432/data_hygiene_prod
ASYNC_DATABASE_URL=postgresql+asyncpg://admin:prodpassword@postgres:5432/data_hygiene_prod

# Database Connection Pool (production settings)
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# Storage (MinIO - simulating GCS)
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=data-hygiene-prod-sim
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# MinIO Ports
MINIO_API_PORT=9000
# Console port not exposed in prod-sim

# API Configuration (production settings)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_WORKERS=4

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Authentication (use strong secrets in real production!)
JWT_SECRET_KEY=prod-sim-secret-key-NOT-for-real-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# NextAuth (if using)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=prod-sim-nextauth-secret-NOT-for-real-production

# Logging
LOG_LEVEL=info

# Python Optimization
PYTHONOPTIMIZE=2

# Node.js Optimization
NODE_OPTIONS=--max-old-space-size=512
