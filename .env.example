# ============================================================================
# Environment Variables - Local Development
# Data Hygiene Toolkit
# 
# Copy this file to .env for local development
# ============================================================================

# Environment
ENVIRONMENT=development
DEBUG=true
BUILD_TARGET=development
NODE_ENV=development

# Database (PostgreSQL)
POSTGRES_USER=admin
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=data_hygiene
POSTGRES_PORT=5432

# Database URLs
DATABASE_URL=postgresql://admin:devpassword@postgres:5432/data_hygiene
ASYNC_DATABASE_URL=postgresql+asyncpg://admin:devpassword@postgres:5432/data_hygiene

# Storage (MinIO - Local S3-compatible)
STORAGE_TYPE=minio
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=data-hygiene-local
STORAGE_REGION=us-east-1
STORAGE_USE_SSL=false

# MinIO Ports
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Frontend Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# JWT Authentication
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# NextAuth (if using)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-nextauth-secret-change-in-production

# Logging
LOG_LEVEL=debug

# Optional: LocalStack (for AWS API)
# LOCALSTACK_ENDPOINT=http://localstack:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test
# AWS_DEFAULT_REGION=us-east-1
