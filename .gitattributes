# Force LF line endings for shell scripts — needed for Linux Docker containers.
# Without this, Windows Git converts LF→CRLF and scripts fail with
# "/usr/bin/env: 'bash\r': No such file or directory" inside containers.
*.sh text eol=lf

# Keep Python, YAML, and config files LF too
*.py  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
*.env text eol=lf
*.env.* text eol=lf
Makefile text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.pyc  binary
*.pyd  binary
*.pyo  binary
